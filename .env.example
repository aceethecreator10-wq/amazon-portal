# ============================================================
# DealFlow Portal — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env or .env.local to version control.
# ============================================================

# --- Supabase Configuration ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Supabase Service Role Key ---
# WARNING: This key bypasses RLS. Use ONLY in server-side code
# (API routes, server actions, migration scripts).
# NEVER prefix with NEXT_PUBLIC_. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Site URL ---
# In development: http://localhost:3000
# In production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Payout Provider Configuration ---
# Options: "razorpayx", "cashfree", "manual"
PAYOUT_PROVIDER=manual
# Set to "true" to enable automated payouts via the configured provider
PAYOUTS_ENABLED=false

# --- RazorpayX Credentials (required if PAYOUT_PROVIDER=razorpayx) ---
RAZORPAYX_KEY_ID=
RAZORPAYX_KEY_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=
RAZORPAYX_WEBHOOK_SECRET=
