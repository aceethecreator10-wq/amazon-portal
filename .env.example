# ============================================================
# DealFlow Portal — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env or .env.local to version control.
# ============================================================

# --- Supabase Configuration ---
# NEXT_PUBLIC_* variables are safe to expose in client-side code.
# Get these from your Supabase project dashboard:
# Settings > API > Project URL & Project API keys

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Supabase Service Role Key ---
# WARNING: This key bypasses RLS. Use ONLY in server-side code
# (API routes, server actions, migration scripts).
# NEVER prefix with NEXT_PUBLIC_. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Site URL ---
# Used for auth redirects and SEO metadata.
# In development: http://localhost:3000
# In production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
